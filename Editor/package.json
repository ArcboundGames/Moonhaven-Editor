{
  "name": "moonhaven-editor",
  "version": "0.1.0",
  "productName": "MoonhavenEditor",
  "description": "Modding tool for Moonhaven",
  "license": "MIT",
  "keywords": [
    "electron",
    "boilerplate",
    "react",
    "typescript",
    "ts",
    "sass",
    "webpack",
    "hot",
    "reload"
  ],
  "homepage": "https://github.com/electron-react-boilerplate/electron-react-boilerplate#readme",
  "bugs": {
    "url": "https://github.com/electron-react-boilerplate/electron-react-boilerplate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electron-react-boilerplate/electron-react-boilerplate.git"
  },
  "author": {
    "name": "Electron React Boilerplate Maintainers",
    "email": "electronreactboilerplate@gmail.com",
    "url": "https://electron-react-boilerplate.js.org"
  },
  "contributors": [
    {
      "name": "Amila Welihinda",
      "email": "amilajack@gmail.com",
      "url": "https://github.com/amilajack"
    }
  ],
  "main": "./src/main/main.ts",
  "scripts": {
    "build:main": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.main.prod.ts",
    "build:renderer": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.renderer.prod.ts",
    "build": "concurrently \"npm run build:main\" \"npm run build:renderer\"",
    "data:combine": "ts-node src/scripts/combine-data.ts",
    "data:split": "ts-node src/scripts/split-data.ts",
    "lint": "cross-env NODE_ENV=development eslint .",
    "package": "ts-node ./.erb/scripts/clean.js dist && npm run build && electron-builder build --publish never",
    "postinstall": "ts-node .erb/scripts/check-native-dep.js && electron-builder install-app-deps && cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.renderer.dev.dll.ts",
    "rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir release/app",
    "start:main": "cross-env NODE_ENV=development NODE_OPTIONS=--import=tsx electronmon .",
    "start:preload": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.preload.dev.ts",
    "start:renderer": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack serve --config ./.erb/configs/webpack.config.renderer.dev.ts",
    "start": "ts-node ./.erb/scripts/check-port-in-use.js && npm run start:renderer",
    "test": "jest",
    "type-check:watch": "npm run type-check -- --watch",
    "type-check": "tsc --noEmit",
    "wiki": "ts-node src/wiki/index.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "cross-env NODE_ENV=development eslint --cache"
    ],
    "*.json,.{eslintrc,prettierrc}": [
      "prettier --parser json --write"
    ],
    "*.{css,scss}": [
      "prettier --single-quote --write"
    ],
    "*.{html,md,yml}": [
      "prettier --single-quote --write"
    ]
  },
  "browserslist": [],
  "prettier": {
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ],
    "trailingComma": "none",
    "singleQuote": true,
    "printWidth": 120
  },
  "jest": {
    "moduleDirectories": [
      "node_modules",
      "release/app/node_modules",
      "src"
    ],
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/.erb/mocks/fileMock.js",
      "\\.(css|less|sass|scss)$": "identity-obj-proxy"
    },
    "setupFiles": [
      "./.erb/scripts/check-build-exists.ts"
    ],
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost/"
    },
    "testPathIgnorePatterns": [
      "release/app/dist"
    ],
    "transform": {
      "\\.(ts|tsx|js|jsx)$": "ts-jest"
    }
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/system": "^7.3.8",
    "@mui/x-date-pickers": "^8.27.2",
    "@reduxjs/toolkit": "^2.11.2",
    "date-fns": "^3.6.0",
    "electron-log": "^5.4.3",
    "image-size": "1.0.2",
    "path-browserify": "1.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@babel/core": "7.25.2",
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.3",
    "@emotion/eslint-plugin": "11.12.0",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@pmmmwh/react-refresh-webpack-plugin": "0.5.15",
    "@svgr/webpack": "^8.1.0",
    "@teamsupercell/typings-for-css-modules-loader": "2.5.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "18.19.130",
    "@types/path-browserify": "1.0.3",
    "@types/prettier": "^2.7.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webpack-bundle-analyzer": "4.7.0",
    "browserslist-config-erb": "0.0.3",
    "chalk": "4.1.2",
    "concurrently": "7.6.0",
    "core-js": "3.38.1",
    "cross-env": "7.0.3",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "4.2.2",
    "detect-port": "1.6.1",
    "dotenv": "^16.5.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-debug": "^4.1.0",
    "electron-devtools-installer": "^4.0.0",
    "electron-updater": "^6.8.3",
    "electronmon": "^2.0.4",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-import-resolver-webpack": "0.13.10",
    "eslint-plugin-babel": "5.3.1",
    "eslint-plugin-compat": "7.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jsx-a11y": "6.10.0",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "file-loader": "6.2.0",
    "globals": "^15.0.0",
    "html-webpack-plugin": "5.6.0",
    "identity-obj-proxy": "3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "13.3.0",
    "mini-css-extract-plugin": "2.9.1",
    "prettier": "2.8.8",
    "react-refresh": "0.14.0",
    "rimraf": "3.0.2",
    "sass": "1.78.0",
    "sass-loader": "^16.0.7",
    "style-loader": "3.3.4",
    "terser-webpack-plugin": "5.3.10",
    "ts-jest": "^29.4.6",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "url-loader": "4.1.1",
    "webpack": "5.94.0",
    "webpack-bundle-analyzer": "4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1",
    "wikiapi": "1.20.0"
  },
  "build": {
    "productName": "MoonhavenEditor",
    "appId": "org.arcboundgames.MoonhavenEditor",
    "asar": true,
    "asarUnpack": "**\\*.{node,dll}",
    "files": [
      "dist",
      "node_modules",
      "package.json"
    ],
    "afterSign": ".erb/scripts/notarize.js",
    "mac": {
      "target": {
        "target": "default",
        "arch": [
          "arm64",
          "x64"
        ]
      },
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "directories": {
      "app": "release/app",
      "buildResources": "assets",
      "output": "release/build"
    },
    "extraResources": [
      "./assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "electron-react-boilerplate",
      "repo": "electron-react-boilerplate"
    }
  },
  "overrides": {
    "@emotion/eslint-plugin": {
      "eslint": "^9.0.0"
    }
  },
  "collective": {
    "url": "https://opencollective.com/electron-react-boilerplate-594"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.x",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11.x",
      "onFail": "error"
    }
  },
  "electronmon": {
    "patterns": [
      "!**/**",
      "src/main/**"
    ],
    "logLevel": "quiet"
  }
}
